# syntax=docker/dockerfile:1.7
#
# Spring Voyage — DEPRECATED legacy agent runtime image.
#
# This file used to be the Debian + Node + Python "delegated execution"
# base image, tagged `localhost/spring-voyage-agent:latest`. PR 3b of
# #1087 (#1096) splits the world into:
#
#   * `Dockerfile.agent-base`        — A2A bridge sidecar base (path 1)
#   * `Dockerfile.agent.claude-code` — Claude Code on top of agent-base
#   * `Dockerfile.agent.dapr`        — Dapr Agent native A2A image (path 3)
#
# To avoid breaking operators who still build with `deploy.sh build` and
# the existing example Dockerfiles, this file is preserved as a thin
# legacy alias that simply `FROM`s the new agent-base image. The output
# tag (`localhost/spring-voyage-agent:latest`) is now functionally
# identical to `localhost/spring-voyage-agent-claude-code:latest` minus
# the Claude Code CLI install — i.e. the agent-base image. New manifests
# should reference one of the per-tool images directly.
#
# Removal target: PR 4 of #1087, which lands the launcher changes that
# make per-tool image references the only supported path.

ARG AGENT_BASE_IMAGE=ghcr.io/cvoya-com/agent-base:1.0.0

FROM ${AGENT_BASE_IMAGE}
