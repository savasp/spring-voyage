# syntax=docker/dockerfile:1.7
#
# Spring Voyage — spring-voyage-agents omnibus image (#1514).
#
# Platform default for unit creation: the wizard pre-fills
# `ghcr.io/cvoya-com/spring-voyage-agents:latest` and any unit without an
# operator-provided image uses this one. It bundles all OSS CLI runtimes on
# top of the minimal `spring-voyage-agent-base` BYOI image so an operator can
# run a unit with any of the four supported runtimes (Claude, OpenAI/Codex,
# Google/Gemini, Ollama/dapr-agent) out of the box.
#
# Image taxonomy:
#   spring-voyage-agent-base:latest  — BYOI minimal (A2A sidecar + Node 22 +
#                                      Python 3.13 on Debian trixie). Operators
#                                      who want to bring their own CLI layer
#                                      FROM this.
#   spring-voyage-agents:latest      — Omnibus (this file). Strict superset of
#                                      agent-base: layers all four CLI runtimes
#                                      on top. The wizard default.
#
# Runtime CLIs bundled:
#   claude    — @anthropic-ai/claude-code@CLAUDE_CODE_VERSION (npm global)
#   codex     — @openai/codex@CODEX_VERSION                   (npm global)
#   gemini    — @google/gemini-cli@GEMINI_CLI_VERSION          (npm global)
#   dapr-agent stack (Python venv) — for the OpenAI, Google, and Ollama
#                runtimes that all use ToolKind="dapr-agent"
#
# Versions are pinned as ARGs at the top so bumps are a single-line edit;
# all three CLI versions are recorded in labels for auditability.
#
# Build (from repo root):
#   docker build \
#     -f deployment/Dockerfile.spring-voyage-agents \
#     -t ghcr.io/cvoya-com/spring-voyage-agents:dev \
#     .

ARG AGENT_BASE_IMAGE=ghcr.io/cvoya-com/spring-voyage-agent-base:latest
ARG CLAUDE_CODE_VERSION=2.1.98
ARG CODEX_VERSION=0.128.0
ARG GEMINI_CLI_VERSION=0.40.1

FROM ${AGENT_BASE_IMAGE}

# Re-declare ARGs after FROM so they are in scope for the RUN steps below.
ARG CLAUDE_CODE_VERSION
ARG CODEX_VERSION
ARG GEMINI_CLI_VERSION

USER root

# ---- OSS CLI installs (npm globals) -----------------------------------------
# 1. Claude Code CLI (@anthropic-ai/claude-code → `claude` binary)
RUN npm install -g "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
 && command -v claude >/dev/null \
 && claude --version

# 2. OpenAI Codex CLI (@openai/codex → `codex` binary)
RUN npm install -g "@openai/codex@${CODEX_VERSION}" \
 && command -v codex >/dev/null

# 3. Google Gemini CLI (@google/gemini-cli → `gemini` binary)
RUN npm install -g "@google/gemini-cli@${GEMINI_CLI_VERSION}" \
 && command -v gemini >/dev/null

# ---- dapr-agent stack -------------------------------------------------------
# Python 3.13 from agent-base satisfies spring-voyage-agent's
# python_requires>=3.12. We build the venv in-place; no multi-stage hop or
# --break-system-packages dance needed because the venv is an isolated prefix.
COPY agents/dapr-agent/requirements.txt /tmp/dapr-agent-requirements.txt
COPY agents/spring-voyage-agent         /tmp/spring-voyage-agent

RUN python3 -m venv /opt/dapr-agent-venv \
 && /opt/dapr-agent-venv/bin/pip install --no-cache-dir -r /tmp/dapr-agent-requirements.txt \
 && /opt/dapr-agent-venv/bin/pip install --no-cache-dir /tmp/spring-voyage-agent \
 && rm -rf /tmp/dapr-agent-requirements.txt /tmp/spring-voyage-agent \
 && chown -R agent:agent /opt/dapr-agent-venv

# Copy the dapr-agent Python source. Mirrors the COPY recipe in
# Dockerfile.agent.dapr so the dispatcher's SPRING_AGENT_ARGV path is
# consistent across the standalone dapr-agent image and the omnibus.
COPY agents/dapr-agent/agent.py        /opt/spring-voyage/dapr-agent/agent.py
COPY agents/dapr-agent/a2a_server.py   /opt/spring-voyage/dapr-agent/a2a_server.py
COPY agents/dapr-agent/mcp_bridge.py   /opt/spring-voyage/dapr-agent/mcp_bridge.py
COPY agents/dapr-agent/pyproject.toml  /opt/spring-voyage/dapr-agent/pyproject.toml

RUN chown -R agent:agent /opt/spring-voyage/dapr-agent

USER agent

# ---- labels -----------------------------------------------------------------
LABEL org.opencontainers.image.title="spring-voyage-agents" \
      org.opencontainers.image.description="Spring Voyage omnibus agent image: bundles the Claude Code, OpenAI Codex, and Google Gemini CLIs plus the dapr-agent Python stack on top of spring-voyage-agent-base. Platform default for unit creation." \
      org.opencontainers.image.source="https://github.com/cvoya-com/spring-voyage" \
      com.cvoya.spring-voyage.claude-code-version="${CLAUDE_CODE_VERSION}" \
      com.cvoya.spring-voyage.codex-version="${CODEX_VERSION}" \
      com.cvoya.spring-voyage.gemini-cli-version="${GEMINI_CLI_VERSION}"

# Entrypoint inherited from spring-voyage-agent-base: tini → node sidecar.
# The dispatcher sets SPRING_AGENT_ARGV to choose the active CLI:
#
#   SPRING_AGENT_ARGV='["claude","--dangerously-skip-permissions"]'  # Claude
#   SPRING_AGENT_ARGV='["codex","--full-auto"]'                      # Codex
#   SPRING_AGENT_ARGV='["gemini","--yolo"]'                          # Gemini
#   SPRING_AGENT_ARGV='["/opt/dapr-agent-venv/bin/python","/opt/spring-voyage/dapr-agent/agent.py"]'  # dapr-agent
#
# Do NOT override ENTRYPOINT unless you are implementing BYOI path 3 (native
# A2A — see docs/architecture/agent-images.md).
