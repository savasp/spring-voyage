# Spring Voyage — deployment environment file
#
# Copy to spring.env and fill in values. DO NOT commit spring.env.
# This file is loaded by deploy.sh and passed to Podman as --env-file.
#
# All values are plain KEY=VALUE pairs (no quoting, no shell expansion).

# ---------------------------------------------------------------------------
# Image tags. The deploy scripts pull/build these tags and run them.
# ---------------------------------------------------------------------------
SPRING_IMAGE_TAG=latest
SPRING_PLATFORM_IMAGE=localhost/spring-voyage:${SPRING_IMAGE_TAG}
SPRING_AGENT_IMAGE=localhost/spring-voyage-agent:${SPRING_IMAGE_TAG}

# Optional: override stock images.
POSTGRES_IMAGE=docker.io/library/postgres:17
REDIS_IMAGE=docker.io/library/redis:7
CADDY_IMAGE=docker.io/library/caddy:2

# ---------------------------------------------------------------------------
# PostgreSQL (spring-postgres container)
# ---------------------------------------------------------------------------
POSTGRES_USER=spring
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=spring

# ---------------------------------------------------------------------------
# Redis (spring-redis container) — used by Dapr state store and pub/sub.
# Leave REDIS_PASSWORD empty to disable auth (local dev only).
# ---------------------------------------------------------------------------
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Platform connection strings (spring-api and spring-worker)
# These are consumed by the .NET hosts via IConfiguration.
# ---------------------------------------------------------------------------
ConnectionStrings__Postgres=Host=spring-postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
ConnectionStrings__Redis=spring-redis:6379

# ---------------------------------------------------------------------------
# Dapr component secrets (resolved by dapr/components/production/*.yaml via
# secretstores.local.env — i.e. read from this file's environment by the
# sidecar). Keep in sync with the secretKeyRef entries in those components.
# ---------------------------------------------------------------------------
SPRING_POSTGRES_CONNECTION_STRING=host=spring-postgres port=5432 user=${POSTGRES_USER} password=${POSTGRES_PASSWORD} dbname=${POSTGRES_DB} sslmode=disable

# Path to the Dapr components directory mounted into delegated-agent Dapr
# sidecars. Override if you ship a custom profile per tenant/environment.
ContainerRuntime__DaprComponentsPath=/dapr/components/production

# ---------------------------------------------------------------------------
# ASP.NET Core + host configuration
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080
DOTNET_NOLOGO=true
DOTNET_CLI_TELEMETRY_OPTOUT=true

# ---------------------------------------------------------------------------
# Authentication mode for the API host.
#
# LocalDev=true installs the LocalDevAuthHandler, which authenticates every
# request as the default local user. This is the right default for a single-
# operator Podman deployment where the web portal does not yet carry per-user
# tokens — without it, every authorized API call from the browser returns
# 401 (#260, #261).
#
# For multi-user / hosted deployments, leave this unset and provision API
# tokens via /api/v1/auth/tokens; future work will plumb those tokens through
# the web portal's fetch layer.
# ---------------------------------------------------------------------------
LocalDev=true

# Root of the unit-template + skill-bundle catalog. The Dockerfile copies the
# repository's packages/ tree to /packages; point the catalog at it so the
# wizard's Template step (#260) and manifest skill references work in-container.
Packages__Root=/packages

# ---------------------------------------------------------------------------
# Caddy / public hostnames.
#
# DEPLOY_HOSTNAME is the single-host default used by the path-routed
# Caddyfile. Set it to your FQDN in production to enable automatic TLS via
# Let's Encrypt. Leave as "localhost" (or use :80 behavior) for local dev.
#
# For per-service hostnames (app.example.com, api.example.com,
# hooks.example.com) set WEB_HOSTNAME / API_HOSTNAME / WEBHOOK_HOSTNAME and
# switch to the multi-host Caddyfile via SPRING_CADDYFILE below. When any
# of those three are unset they fall back to DEPLOY_HOSTNAME.
#
# ACME_EMAIL is the Let's Encrypt contact address used for expiry /
# revocation notices. Recommended when using public FQDNs.
# ---------------------------------------------------------------------------
DEPLOY_HOSTNAME=localhost
# WEB_HOSTNAME=app.example.com
# API_HOSTNAME=api.example.com
# WEBHOOK_HOSTNAME=hooks.example.com
# ACME_EMAIL=ops@example.com

# Caddyfile variant mounted into spring-caddy. Default: "Caddyfile" (single
# host, path-routed). Set to "Caddyfile.multi-host" for per-service
# hostnames. Absolute paths are also accepted.
# SPRING_CADDYFILE=Caddyfile.multi-host

# ---------------------------------------------------------------------------
# Secrets consumed by the platform / connectors. Uncomment as needed.
# ---------------------------------------------------------------------------
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Remote deploy (consumed by deploy-remote.sh). Override on the command line
# or via environment — they are NOT passed into containers.
# ---------------------------------------------------------------------------
# SPRING_REMOTE_HOST=user@vps.example.com
# SPRING_REMOTE_DIR=/opt/spring-voyage
# SPRING_REMOTE_SSH_OPTS=

# ---------------------------------------------------------------------------
# Webhook relay (consumed by relay.sh — local-dev SSH reverse tunnel that
# forwards a public port on a relay VPS to a webhook endpoint on a dev
# laptop). Not passed into containers.
# ---------------------------------------------------------------------------
# RELAY_HOST=relay.example.com
# RELAY_USER=webhooks
# RELAY_SSH_PORT=22
# RELAY_REMOTE_PORT=19080
# RELAY_BIND_ADDRESS=127.0.0.1
# LOCAL_WEBHOOK_PORT=8080
# LOCAL_WEBHOOK_HOST=127.0.0.1
# RELAY_SSH_KEY=~/.ssh/relay_ed25519
# RELAY_EXTRA_SSH_OPTS=
# RELAY_RECONNECT_DELAY=5
