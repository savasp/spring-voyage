# Spring Voyage — Caddy reverse proxy (single-host, path-routed).
#
# This is the default Caddyfile used when all three services (web portal,
# API, and webhook endpoint) share a single public hostname and are
# disambiguated by URL path. It is the simplest setup for a single VPS.
#
# For per-service hostnames (e.g. app.example.com, api.example.com,
# hooks.example.com) use Caddyfile.multi-host instead — mount it to
# /etc/caddy/Caddyfile by pointing SPRING_CADDYFILE at that path.
#
# Environment variables (all substituted by Caddy at container start):
#
#   DEPLOY_SCHEME    "http" for local dev (no TLS, default) or "https"
#                    for a real FQDN deployment with automatic Let's
#                    Encrypt certificates.
#   DEPLOY_HOSTNAME  Public FQDN for all routes. Leave as "localhost"
#                    (the default) with DEPLOY_SCHEME=http. Set to a
#                    real FQDN with public DNS + ports 80/443 reachable
#                    and DEPLOY_SCHEME=https to enable auto-TLS.
#   ACME_EMAIL       Contact email for Let's Encrypt expiry / revocation
#                    notices. Optional. If set for a real FQDN deployment,
#                    add a global block at the top of this file:
#                      { email {$ACME_EMAIL} }

{$DEPLOY_SCHEME:http}://{$DEPLOY_HOSTNAME:localhost} {
    encode zstd gzip

    # Webhook endpoint — inbound events from third-party providers
    # (GitHub, etc.). Signature validation happens inside the API.
    handle /api/v1/webhooks/* {
        reverse_proxy spring-api:8080
    }

    # Next.js SSE route handlers. These live in the portal process
    # (src/Cvoya.Spring.Web/src/app/api/stream/**/route.ts) because
    # EventSource is same-origin and cookie-bound; the route handler
    # proxies the platform's SSE stream to the browser while keeping
    # auth cookies intact. Must precede the generic `/api/*` rule so
    # Caddy doesn't send stream requests to spring-api (which only
    # exposes `/api/v1/activity/stream`, not `/api/stream/activity`).
    handle /api/stream/* {
        reverse_proxy spring-web:3000
    }

    # REST API, OpenAPI docs, and health probe.
    handle /api/* {
        reverse_proxy spring-api:8080
    }

    handle /openapi/* {
        reverse_proxy spring-api:8080
    }

    handle /health {
        reverse_proxy spring-api:8080
    }

    # Everything else: Next.js web portal.
    handle {
        reverse_proxy spring-web:3000
    }
}

# --------------------------------------------------------------------------
# Tenant-to-platform ingress — ADR 0028 Decision D.
#
# Agent containers and workflow containers run on the per-tenant bridge
# network (spring-tenant-default). They reach the platform's authenticated
# public Web API at http://spring-caddy:8443 from inside that network —
# the same authenticated path external clients use, with no special-case
# routing or direct-infra-access shortcuts.
#
# Caddy is dual-attached to spring-net (platform) and spring-tenant-default
# (tenant) so it is reachable from both sides. The DNS name "spring-caddy"
# resolves via Docker/Podman container DNS within any network the container
# is attached to.
#
# Port 8443 is used for the tenant-facing listener to avoid colliding with
# the host-published ports 80/443 that are reserved for external traffic.
# This is a plain HTTP listener on the internal network — TLS between tenant
# containers and Caddy on a container-internal path is tracked in #1375.
#
# Authorization is enforced by the API host's auth middleware; Caddy only
# proxies and does not add or strip auth headers on this path.
# --------------------------------------------------------------------------
:8443 {
    # All tenant→platform traffic is destined for the REST API. The tenant
    # containers use the full /api/v1/... paths, matching the same surface
    # external clients use.
    handle /api/* {
        reverse_proxy spring-api:8080
    }

    handle /health {
        reverse_proxy spring-api:8080
    }

    # Reject everything else — tenant containers must not discover or reach
    # the web portal or internal endpoints through this listener.
    handle {
        respond 404
    }
}
