# Spring Voyage — Caddy reverse proxy (single-host, path-routed).
#
# This is the default Caddyfile used when all three services (web portal,
# API, and webhook endpoint) share a single public hostname and are
# disambiguated by URL path. It is the simplest setup for a single VPS.
#
# For per-service hostnames (e.g. app.example.com, api.example.com,
# hooks.example.com) use Caddyfile.multi-host instead — mount it to
# /etc/caddy/Caddyfile by pointing SPRING_CADDYFILE at that path.
#
# Environment variables (all substituted by Caddy at container start):
#
#   DEPLOY_SCHEME    "http" for local dev (no TLS, default) or "https"
#                    for a real FQDN deployment with automatic Let's
#                    Encrypt certificates.
#   DEPLOY_HOSTNAME  Public FQDN for all routes. Leave as "localhost"
#                    (the default) with DEPLOY_SCHEME=http. Set to a
#                    real FQDN with public DNS + ports 80/443 reachable
#                    and DEPLOY_SCHEME=https to enable auto-TLS.
#   ACME_EMAIL       Contact email for Let's Encrypt expiry / revocation
#                    notices. Optional. If set for a real FQDN deployment,
#                    add a global block at the top of this file:
#                      { email {$ACME_EMAIL} }

{$DEPLOY_SCHEME:http}://{$DEPLOY_HOSTNAME:localhost} {
    encode zstd gzip

    # Webhook endpoint — inbound events from third-party providers
    # (GitHub, etc.). Signature validation happens inside the API.
    handle /api/v1/webhooks/* {
        reverse_proxy spring-api:8080
    }

    # REST API, OpenAPI docs, and health probe.
    handle /api/* {
        reverse_proxy spring-api:8080
    }

    handle /openapi/* {
        reverse_proxy spring-api:8080
    }

    handle /health {
        reverse_proxy spring-api:8080
    }

    # Everything else: Next.js web portal.
    handle {
        reverse_proxy spring-web:3000
    }
}
